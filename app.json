{
  "expo": {
    "name": "dezik-log",
    "slug": "dezik-log",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "deziklog",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "description": "Цифровий журнал стерилізації для б'юті-майстрів",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shineshopb2b.deziklog",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Dezik Log потребує доступ до камери для фотографування індикаторів стерилізації",
        "NSPhotoLibraryUsageDescription": "Dezik Log потребує доступ до фото для вибору фото індикаторів стерилізації",
        "NSPhotoLibraryAddUsageDescription": "Dezik Log потребує доступ для збереження фото індикаторів"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Дозвольте доступ до камери для фотографування індикаторів стерилізації."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Дозвольте доступ до фото для фотографування індикаторів стерилізації.",
          "cameraPermission": "Дозвольте доступ до камери для фотографування індикаторів стерилізації."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "58da0a89-afb9-4ed0-8c18-11f402dd9cd7"
      }
    }
  }
}
